# mcpmeter proxy — environment

# --- Server ---
HOST=127.0.0.1
PORT=3010

# --- MySQL (same DB as the Laravel app) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=gejadze
DB_PASSWORD=
DB_NAME=mcpmeter

# --- Redis (auth cache, rate-limit windows, MCP config cache) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=2

# --- Behaviour ---
LOG_LEVEL=info
TRUST_PROXY=true
KEY_CACHE_TTL_SECONDS=300
MCP_CACHE_TTL_SECONDS=300
UPSTREAM_TIMEOUT_MS=15000

# Platform default rate limits when an MCP leaves them null.
DEFAULT_RPM=60
DEFAULT_RPD=10000
